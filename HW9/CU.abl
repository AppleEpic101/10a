    " Control Unit Top Level
    RD = 0;
    WR = 0;
    SelectDB1 = 0;
    SelectDB0 = 0;
    OffsetSel = 0;
}

WHEN (IR == JNE) THEN {
    " PAU: branch if zero bit clear (not equal)
    WHEN (Flags0 == 0) THEN { 
