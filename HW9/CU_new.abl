Group_PAU_Increment_PC = Inst_ADCM # Inst_ADCXO # Inst_ADCSO # Inst_ADCI # Inst_ADDM # Inst_ADDXO # Inst_ADDSO # Inst_ADDI # Inst_ANDM # Inst_ANDXO # Inst_ANDSO # Inst_ANDI # Inst_CMPM # Inst_CMPXO # Inst_CMPSO # Inst_CMPI # Inst_DEC # Inst_INC # Inst_LSL # Inst_NOT # Inst_ORM # Inst_ORXO # Inst_ORSO # Inst_ORI # Inst_RLC # Inst_SBBM # Inst_SBBXO # Inst_SBBSO # Inst_SBBI # Inst_SUBM # Inst_SUBXO # Inst_SUBSO # Inst_SUBI # Inst_TSTM # Inst_TSTXO # Inst_TSTSO # Inst_TSTI # Inst_XORM # Inst_XORXO # Inst_XORSO # Inst_XORI # Inst_POPF # Inst_PUSHF # Inst_NOP # Inst_LDI # Inst_LDD # Inst_LDXO # Inst_LDXO_I # Inst_LDXO_D # Inst_I_LDXO # Inst_D_LDXO # Inst_LDSO # Inst_LDSO_I # Inst_LDSO_D # Inst_I_LDSO # Inst_D_LDSO # Inst_STD # Inst_STXO # Inst_STXO_I # Inst_STXO_D # Inst_I_STXO # Inst_D_STXO # Inst_STSO # Inst_STSO_I # Inst_STSO_D # Inst_I_STSO # Inst_D_STSO;
