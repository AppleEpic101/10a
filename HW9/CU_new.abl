MODULE CUInterface

INTERFACE (ProgramDB15..ProgramDB0, Flags7..Flags0, Reset, Clock ->
        MuxSel2..MuxSel0, Load, " PAU

        UpdateAcc, OpSelect, UseAdder, F3..F0, CinSel1..CinSel0, InvertCarry, " ALU
        LSBselect1..LSBselect0, MiddleSelect, MSBselect2..MSBselect0,
        MaskSZ, MaskVC, PopF, 

        EnableInc, UseOffset, AddressSel1..AddressSel0, UseInc, UsePost,  " DAU
        MaskS, MaskX,
        
        OffsetSel, SelectDB1..SelectDB0, RD, WR, IO, Address12..Address0);

TITLE 'Control Unit'

" Inputs
ProgramDB15..ProgramDB0     pin; " Program Data Bus
Flags7..Flags0              pin; 

Reset                       pin; 
Clock                       pin; 

" Outputs

" PAU
MuxSel2..MuxSel0            pin; 
Load                        pin; 

" ALU
UpdateAcc                   pin; 
OpSelect                    pin; 
UseAdder                    pin; 
F3..F0                      pin; 
CinSel1..CinSel0            pin; 
InvertCarry                 pin; 
LSBselect1..LSBselect0      pin; 
MiddleSelect                pin; 
MSBselect2..MSBselect0      pin; 
MaskSZ                      pin; 
MaskVC                      pin;
PopF                        pin; 


" DAU
EnableInc                   pin; 
UseOffset                   pin; 
AddressSel1..AddressSel0    pin; 
UseInc                      pin; 
UsePost                     pin; 
MaskS                       pin; 
MaskX                       pin; 

" Control Unit 
IR15..IR0                   pin ISTYPE 'REG'; " Instruction Register

OffsetSel                   pin; " Selects between low-8 bits of IR (0) or DDB (1) going into PAU offset
SelectDB1..SelectDB0      pin; " Select lines for Data data bus
RD                        pin; " Read 
WR                        pin; " Write
IO                        pin; " I/O    
Address12..Address0       pin; " low 13-bits of IR into address units

" Buses
ProgramDB = [ProgramDB15..ProgramDB0]; " Program Data Bus
Flags     = [Flags7..Flags0];     " Flags Bus
IR        = [IR15..IR0];        " Instruction Register

" Instructions

ADCM   = [0, 1, 1, 0, 0, 0, 0, 0, .X., .X., .X., .X., .X., .X., .X., .X.];
ADCXO  = [0, 1, 1, 0, 0, 0, 0, 1, .X., .X., .X., .X., .X., .X., .X., .X.];
